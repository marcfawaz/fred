# This file contains the secret and access keys environment variables

# -----------------------------------------------------------------------------
# CONFIGURATION
# -----------------------------------------------------------------------------

CONFIG_FILE="./config/configuration.yaml"

# Keycloak Agentic Token so that agentic can succesfully invoke
# the knowledge-flow backend if keycloak is on.

# -----------------------------------------------------------------------------
# 🟠 KEYCLOAK
# -----------------------------------------------------------------------------

KEYCLOAK_AGENTIC_CLIENT_SECRET=""
# Keycloak Knowledge Flow Token so that knowledge-flow can successfully invoke other services if keycloak is on.

# -----------------------------------------------------------------------------
# 🔵 AZURE AUTHENTICATION (for getting OAuth token)
# -----------------------------------------------------------------------------

AZURE_AD_CLIENT_SECRET=""
# Client Secret of your Azure AD Application

# -----------------------------------------------------------------------------
# 🔵 API GATEWAY (APIM) SETTINGS
# -----------------------------------------------------------------------------

AZURE_APIM_SUBSCRIPTION_KEY="your-subscription-key"
# Subscription Key required by the APIM Gateway ("TrustNest-Apim-Subscription-Key" header)

# -----------------------------------------------------------------------------
# 🔵 AZURE OPENAI DIRECT SETTINGS (if AZURE_USE_APIM=false)
# -----------------------------------------------------------------------------

AZURE_OPENAI_API_KEY=""
# Azure OpenAI API Key (directly from Azure portal, not APIM key)

# -----------------------------------------------------------------------------
# 🔵 OPENAI (Public API - NOT Azure)
# -----------------------------------------------------------------------------

OPENAI_API_KEY=""
# Your OpenAI API key from https://platform.openai.com/account/api-keys

# -----------------------------------------------------------------------------
# 🟡 GOOGLE / VERTEX AI AUTHENTICATION
# -----------------------------------------------------------------------------

# Local/dev: path to a service-account JSON key file used by ADC.
# Examples:
# - /home/xxx/.config/gcloud/application_default_credentials.json
# - /home/xxx/secrets/fred-vertex-sa.json
# - /app/secrets/fred-vertex-sa.json (inside container)
# On GCP runtime (Workload Identity / metadata), leave empty.
GOOGLE_APPLICATION_CREDENTIALS=""

# -----------------------------------------------------------------------------
# 🟢 Postgres storage configuration
# -----------------------------------------------------------------------------

# Postgres credentials
FRED_POSTGRES_PASSWORD=""

# -----------------------------------------------------------------------------
# 🟢 Opensearch storage configuration
# -----------------------------------------------------------------------------

# Opensearch credentials
OPENSEARCH_PASSWORD=""


# -----------------------------------------------------------------------------
# 🕸️ ReBAC (OpenFGA)
# -----------------------------------------------------------------------------

# Preshared key used to authenticate with the OpenFGA API
OPENFGA_API_TOKEN=""

# -----------------------------------------------------------------------------
#  LLM tracing (Langfuse)
# -----------------------------------------------------------------------------
LANGFUSE_BASE_URL="http://localhost:3001"
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
