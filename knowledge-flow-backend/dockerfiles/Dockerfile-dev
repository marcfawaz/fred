# -----------------------------------------------------------------------------
# Backend development image (hot-reload enabled)
# -----------------------------------------------------------------------------
FROM mirror.gcr.io/python:3.12

ARG USER_NAME=fred-user
ARG USER_ID=1000
ARG GROUP_ID=1000
ARG UV_VERSION=0.7.21
ARG HF_OFFLINE_STRICT=0

# Install required system dependencies
RUN apt-get update && \
    apt-get install -y git curl make net-tools inkscape libgl1 && \
    rm -rf /var/lib/apt/lists/*

# Install uv globally
RUN curl -LsSf https://astral.sh/uv/${UV_VERSION}/install.sh | sh && \
    mv /root/.local/bin/uv /usr/local/bin/uv && \
    chmod +x /usr/local/bin/uv

# Setup user and permissions
RUN groupadd -g ${GROUP_ID} ${USER_NAME} && \
    useradd -u ${USER_ID} -g ${GROUP_ID} -m ${USER_NAME} && \
    mkdir -p /opt/python && \
    chown -R ${USER_ID}:${GROUP_ID} /opt/python

# Set environment variables for uv and Python
ENV UV_PROJECT_ENVIRONMENT=/app/venv
ENV PATH="/app/venv/bin:$PATH"
ENV OPENAI_API_KEY=<MUST_BE_DEFINED>
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV CACHE_HOME=/home/${USER_NAME}/.cache
ENV XDG_CACHE_HOME=${CACHE_HOME}
ENV RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
ENV RERANKER_MODEL_CACHE=${CACHE_HOME}/huggingface/hub
ENV HF_HOME=${CACHE_HOME}
ENV HF_HUB_CACHE=${RERANKER_MODEL_CACHE}
ENV HUGGINGFACE_HUB_CACHE=${RERANKER_MODEL_CACHE}
ENV SENTENCE_TRANSFORMERS_HOME=${RERANKER_MODEL_CACHE}
ENV TRANSFORMERS_CACHE=${RERANKER_MODEL_CACHE}
ENV TORCH_HOME=${CACHE_HOME}/torch
ENV DOCLING_ARTIFACTS_PATH=/app/docling-artifacts
ENV HF_HUB_OFFLINE=${HF_OFFLINE_STRICT}
ENV TRANSFORMERS_OFFLINE=${HF_OFFLINE_STRICT}
ENV HF_HUB_DISABLE_TELEMETRY=1
RUN mkdir -p ${CACHE_HOME} ${RERANKER_MODEL_CACHE} ${TORCH_HOME} ${DOCLING_ARTIFACTS_PATH} && \
    chown -R ${USER_ID}:${GROUP_ID} ${CACHE_HOME} ${DOCLING_ARTIFACTS_PATH}

# Set working directory
WORKDIR /app

# Copy only dependency files first to leverage Docker layer caching
COPY --chown=${USER_ID}:${GROUP_ID} knowledge-flow-backend/Makefile knowledge-flow-backend/pyproject.toml knowledge-flow-backend/uv.lock* knowledge-flow-backend/
COPY --chown=${USER_ID}:${GROUP_ID} fred-core fred-core
COPY --chown=${USER_ID}:${GROUP_ID} scripts scripts

# Copy the rest of the project files
COPY --chown=${USER_ID}:${GROUP_ID} knowledge-flow-backend/knowledge_flow_backend knowledge-flow-backend/

# Switch to the created user
USER ${USER_NAME}

# Set working directory
WORKDIR /app/knowledge-flow-backend

# Install dependencies with uv
RUN make dev

# Expose Fast API port
EXPOSE 8111

# Run the application
ENV PYTHONPATH=/app/knowledge-flow-backend
ENTRYPOINT ["make", "run-local"]
